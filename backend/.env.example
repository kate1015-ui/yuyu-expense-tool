# ===============================================
# AI 自動報帳工具 — 環境變數設定 (複製為 .env)
# ===============================================

# Flask
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_PORT=5000
SECRET_KEY=please-change-this-to-a-random-string

# CORS：允許的前端 origin，支援多個逗號分隔
#   本地開發：http://localhost:5173
#   部署後加上 Vercel URL：http://localhost:5173,https://your-app.vercel.app
FRONTEND_ORIGIN=http://localhost:5173

# ---- Gemini API ----
# 取得: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# ---- Google Maps API ----
# 需啟用 Distance Matrix API / Static Maps API / Places API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
COST_PER_KM=8

# ---- Google Sheets 服務帳號 ----
# 【本地開發】把 JSON 金鑰檔放在 backend/ 目錄下
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json
#
# 【部署到 Railway】把整個 JSON 內容貼到這個環境變數（單行或壓縮都可）
# 部署時【二選一】：此變數存在就優先用它，否則才用檔案
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN..."}

# ---- 每位成員的個人 Google Sheet ID ----
# 每人建一份 Google 試算表，把網址 /d/ 後面的 ID 填進來
# 記得把試算表「分享」給服務帳號 email (Editor 權限)
# 格式：單行 JSON
MEMBER_SHEETS={"黃柏堯":"試算表ID_1","黃聖婷":"試算表ID_2","黃荷舒":"試算表ID_3","黃郁清":"試算表ID_4","許泳玲":"試算表ID_5","林琮堯":"試算表ID_6","陳瑋帆":"試算表ID_7","鄭雅欣":"試算表ID_8"}

# 每人試算表的工作表 tab 名稱（統一）
MEMBER_SHEET_TAB=報帳紀錄
